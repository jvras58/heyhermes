# Copie para .env e ajuste. Tudo é opcional — os padrões estão em src/heyhermes/core/config.py

# ---------- cérebro (hermes-agent via Docker, ver docker-compose.yml) ----------
# A mesma chave é usada pelo container (API_SERVER_KEY) e pelo heyhermes.
# Gere uma chave longa aleatória (mínimo 8 caracteres).
# O modelo/provedor do LLM é configurado no próprio hermes (ver README).
HERMES_API_KEY=troque-por-uma-chave-longa
# HERMES_BASE_URL=http://localhost:8642/v1
# HERMES_MODEL=hermes-agent

# ---------- wake word ----------
# nomes pré-treinados do openWakeWord ou caminho de um .onnx customizado
# WAKE_WORDS=["hey_jarvis"]
# WAKE_WORDS=["models/wake/hey_hermes.onnx"]
# WAKE_THRESHOLD=0.5

# ---------- áudio ----------
# WHISPER_MODEL=small
# LANGUAGE=pt
# PIPER_VOICE=pt_BR-faber-medium

# ---------- conversa ----------
# segundos esperando você começar a falar antes de voltar a dormir
# SPEECH_START_TIMEOUT=6.0
# após responder, continua escutando sem exigir a wake word
# FOLLOW_UP=true

# ---------- dashboard do hermes (http://localhost:9119) ----------
# anotação opcional da senha do dashboard (ninguém lê esta variável);
# o usuário e o hash reais ficam em hermes-data/config.yaml — ver
# docs/hermes-setup.md seção 5 para criar as credenciais
# HERMES_DASHBOARD_PASSWORD=sua-senha
