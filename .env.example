# Copie para .env e ajuste. Tudo é opcional — os padrões estão em src/heyhermes/core/config.py

# ---------- cérebro (hermes-agent via Docker, ver docker-compose.yml) ----------
# A mesma chave é usada pelo container (API_SERVER_KEY) e pelo heyhermes.
# Gere uma chave longa aleatória (mínimo 8 caracteres).
# O modelo/provedor do LLM é configurado no próprio hermes (ver README).
HERMES_API_KEY=troque-por-uma-chave-longa
# HERMES_BASE_URL=http://localhost:8642/v1
# HERMES_MODEL=hermes-agent

# ---------- banco de dados p/ relatórios (via MCP read-only / DBHub) ----------
# O agente consulta o banco por um servidor MCP isolado (db-mcp) que guarda esta
# conexão — o agente nunca vê a senha. Ver docs/relatorios-e-navegador.md.
# Formato DBHub (multi-banco): postgres:// | mysql:// | sqlite:/// | sqlserver://
# Banco no PRÓPRIO Windows? use host.docker.internal (não localhost).
# HEYHERMES_PG_DSN=postgres://usuario:senha@host.docker.internal:5432/meubanco
#   docker compose --profile db up -d
#   docker compose exec hermes hermes mcp add banco --url http://db-mcp:8080/mcp
#
# Banco de EXEMPLO embutido (mini-loja) — teste sem ter um banco:
#   HEYHERMES_PG_DSN=postgres://hermes:hermes@demo-db:5432/loja?sslmode=disable
#   docker compose --profile demo up -d
#
# Trocar de banco = trocar só o DSN (o DBHub é multi-banco):
#   MySQL:  mysql://usuario:senha@host.docker.internal:3306/banco
#   SQLite: sqlite:///opt/data/meu.db

# ---------- ações no host (abrir navegador/relatório no seu PC) ----------
# ENABLE_HOST_ACTIONS=true   # ligar/desligar a ponte de ações
# ALLOW_OPEN_URL=true        # permitir [[ABRIR_SITE ...]] abrir URLs

# ---------- wake word ----------
# nomes pré-treinados do openWakeWord ou caminho de um .onnx customizado
# WAKE_WORDS=["hey_jarvis"]
# WAKE_WORDS=["models/wake/hey_hermes.onnx"]
# WAKE_THRESHOLD=0.5

# ---------- áudio ----------
# WHISPER_MODEL=small
# LANGUAGE=pt
# PIPER_VOICE=pt_BR-faber-medium

# ---------- conversa ----------
# segundos esperando você começar a falar antes de voltar a dormir
# SPEECH_START_TIMEOUT=6.0
# após responder, continua escutando sem exigir a wake word
# FOLLOW_UP=true

# ---------- dashboard do hermes (http://localhost:9119) ----------
# anotação opcional da senha do dashboard (ninguém lê esta variável);
# o usuário e o hash reais ficam em hermes-data/config.yaml — ver
# docs/hermes-setup.md seção 5 para criar as credenciais
# HERMES_DASHBOARD_PASSWORD=sua-senha
