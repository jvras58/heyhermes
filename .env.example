# Copie para .env e ajuste. Tudo é opcional — os padrões estão em src/heyhermes/core/config.py

# ---------- cérebro ----------
# ollama (LLM local + tools deste projeto) | openai (API OpenAI-compatível + tools
# deste projeto) | hermes (hermes-agent da NousResearch via Docker, tools dele)
BACKEND=ollama
OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_HOST=http://localhost:11434

# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# hermes-agent via Docker (ver docker-compose.yml). A mesma HERMES_API_KEY é
# usada pelo container (API_SERVER_KEY) e pelo heyhermes para autenticar.
# HERMES_API_KEY=troque-por-uma-chave-longa
# HERMES_BASE_URL=http://localhost:8642/v1
# HERMES_MODEL=hermes-agent

# ---------- wake word ----------
# nomes pré-treinados do openWakeWord ou caminho de um .onnx customizado
# WAKE_WORDS=["hey_jarvis"]
# WAKE_WORDS=["models/wake/hey_hermes.onnx"]
# WAKE_THRESHOLD=0.5

# ---------- áudio ----------
# WHISPER_MODEL=small
# LANGUAGE=pt
# PIPER_VOICE=pt_BR-faber-medium

# ---------- segurança ----------
# habilita a tool run_powershell (o LLM poderá executar comandos no seu PC!)
ALLOW_SHELL=false
